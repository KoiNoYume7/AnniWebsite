{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd client && npm.cmd run dev"],
      "port": 3000
    },
    {
      "name": "Backend (Node)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd server && npm.cmd run dev"],
      "port": 4000
