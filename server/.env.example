# ─────────────────────────────────────────────
#  AnniBackend — Environment Variables
#  Copy this to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────

# Server
PORT=4000
# Must match your Cloudflare Tunnel domain
FRONTEND_URL=https://yumehana.dev
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ── GitHub OAuth ──
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Callback URL to set there: https://yumehana.dev/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Your GitHub numeric user ID (find at: https://api.github.com/users/KoiNoYume7)
GITHUB_ALLOWED_IDS=

# ── Discord OAuth ──
# Create at: https://discord.com/developers/applications → New Application → OAuth2
# Callback URL to set there: https://yumehana.dev/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Your Discord user ID (Enable Developer Mode → right-click your name → Copy ID)
DISCORD_ALLOWED_IDS=

# ── Google OAuth ──
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Callback URL to set there: https://yumehana.dev/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Your Google account email
GOOGLE_ALLOWED_EMAILS=
