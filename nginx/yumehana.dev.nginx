server {
    listen 80;
    server_name yumehana.dev www.yumehana.dev;

    # Static root lives on the SD card so the site stays up
    # even when the external storage drive is unplugged.
    root /opt/anni/www;
    index index.html;

    access_log /var/log/nginx/anni-access.log;
    error_log  /var/log/nginx/anni-error.log;

    # ── Frontend SPA ──
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ── All API traffic → Node :4000 ──
    location /api/ {
        proxy_pass          http://127.0.0.1:4000;
        proxy_http_version  1.1;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        # Trust the Proto header set by Cloudflare Tunnel — $scheme
        # would always be "http" here since nginx only listens on :80.
        proxy_set_header    X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header    Cookie            $http_cookie;
        proxy_pass_header   Set-Cookie;
        proxy_set_header    Connection        '';
        proxy_connect_timeout 10s;
        proxy_read_timeout    60s;
    }

    # ── SSE stream — disable buffering for real-time events ──
    location /api/spotify/stream {
        proxy_pass          http://127.0.0.1:4000;
        proxy_http_version  1.1;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header    Connection        '';
        proxy_buffering     off;
        proxy_cache         off;
        proxy_read_timeout  86400s;
    }

    # NOTE: /api/stripe/webhook will need proxy_request_buffering off later

    # ── Security headers ──
    add_header X-Frame-Options        "SAMEORIGIN"    always;
    add_header X-Content-Type-Options "nosniff"       always;
    add_header Referrer-Policy        "strict-origin"  always;
}
