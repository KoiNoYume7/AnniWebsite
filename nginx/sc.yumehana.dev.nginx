server {
    listen 80;
    server_name sc.yumehana.dev;

    root /opt/anni/sc;
    index index.html;

    access_log /var/log/nginx/sc-access.log;
    error_log  /var/log/nginx/sc-error.log;

    location / {
        try_files $uri $uri/ =404;
    }

    # Short cache for data files (cfg.dat / status.json updated by update-cfg.ps1)
    location ~* \.(css|js|json|svg|ico|png|dat|txt|woff2?)$ {
        expires 1h;
        add_header Cache-Control "public";
    }

    add_header X-Frame-Options        "SAMEORIGIN"    always;
    add_header X-Content-Type-Options "nosniff"       always;
    add_header Referrer-Policy        "strict-origin"  always;
}
